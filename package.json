{
  "name": "parallel-codex-tui",
  "version": "0.1.1",
  "description": "A TypeScript TUI wrapper for routed parallel coding with Codex and Claude workers.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "codex",
    "claude",
    "tui",
    "parallel-coding",
    "agent-orchestration"
  ],
  "engines": {
    "node": ">=26.0.0"
  },
  "bin": {
    "parallel-codex-tui": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    ".parallel-codex/config.example.toml"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@xterm/headless": "^6.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
